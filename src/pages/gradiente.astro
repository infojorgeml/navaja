---
import BaseLayout from '../layouts/BaseLayout.astro';
import Page from '../components/Page.astro';
import GradientTool from '../components/GradientTool.astro';
import { getLocale, useTranslations } from '../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.gradiente.title')} description={t('tool.gradiente.lead')}>
  <Page title={t('tool.gradiente.title')} lead={t('tool.gradiente.lead')} size="wide">
    <GradientTool />
  </Page>
</BaseLayout>
