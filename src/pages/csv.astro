---
import BaseLayout from '../layouts/BaseLayout.astro';
import Page from '../components/Page.astro';
import CsvJsonTool from '../components/CsvJsonTool.astro';
import { getLocale, useTranslations } from '../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.csv.title')} description={t('tool.csv.lead')}>
  <Page title={t('tool.csv.title')} lead={t('tool.csv.lead')} size="wide">
    <CsvJsonTool />
  </Page>
</BaseLayout>
