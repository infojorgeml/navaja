---
import BaseLayout from '../layouts/BaseLayout.astro';
import Page from '../components/Page.astro';
import PasswordGenerator from '../components/PasswordGenerator.astro';

const title = 'Generador de contraseñas';
const description =
  'Crea contraseñas seguras y aleatorias con el nivel de complejidad que elijas.';
---

<BaseLayout title={title} description={description}>
  <Page title={title} lead={description} size="wide">
    <PasswordGenerator />
  </Page>
</BaseLayout>
