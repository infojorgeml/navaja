---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import UrlConverter from '../../components/UrlConverter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.url.title')} description={t('tool.url.lead')}>
  <Page title={t('tool.url.title')} lead={t('tool.url.lead')} size="wide">
    <UrlConverter />
  </Page>
</BaseLayout>
