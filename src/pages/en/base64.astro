---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import Base64Converter from '../../components/Base64Converter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.base64.title')} description={t('tool.base64.lead')}>
  <Page title={t('tool.base64.title')} lead={t('tool.base64.lead')} size="wide">
    <Base64Converter />
  </Page>
</BaseLayout>
