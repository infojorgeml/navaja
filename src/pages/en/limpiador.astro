---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import TextCleaner from '../../components/TextCleaner.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.limpiador.title')} description={t('tool.limpiador.lead')}>
  <Page title={t('tool.limpiador.title')} lead={t('tool.limpiador.lead')} size="wide">
    <TextCleaner />
  </Page>
</BaseLayout>
