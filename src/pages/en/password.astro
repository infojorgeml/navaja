---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import PasswordGenerator from '../../components/PasswordGenerator.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.password.title')} description={t('tool.password.lead')}>
  <Page title={t('tool.password.title')} lead={t('tool.password.lead')} size="wide">
    <PasswordGenerator />
  </Page>
</BaseLayout>
