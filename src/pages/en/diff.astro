---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import DiffChecker from '../../components/DiffChecker.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.diff.title')} description={t('tool.diff.lead')}>
  <Page title={t('tool.diff.title')} lead={t('tool.diff.lead')} size="wide">
    <DiffChecker />
  </Page>
</BaseLayout>
