---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import BinaryConverter from '../../components/BinaryConverter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.binario.title')} description={t('tool.binario.lead')}>
  <Page title={t('tool.binario.title')} lead={t('tool.binario.lead')} size="wide">
    <BinaryConverter />
  </Page>
</BaseLayout>
