---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import NamingGenerator from '../../components/NamingGenerator.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.naming.title')} description={t('tool.naming.lead')}>
  <Page title={t('tool.naming.title')} lead={t('tool.naming.lead')} size="wide">
    <NamingGenerator />
  </Page>
</BaseLayout>
