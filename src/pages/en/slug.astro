---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import SlugGenerator from '../../components/SlugGenerator.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.slug.title')} description={t('tool.slug.lead')}>
  <Page title={t('tool.slug.title')} lead={t('tool.slug.lead')} size="wide">
    <SlugGenerator />
  </Page>
</BaseLayout>
