---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import TextConverter from '../../components/TextConverter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.conversor.title')} description={t('tool.conversor.lead')}>
  <Page title={t('tool.conversor.title')} lead={t('tool.conversor.lead')} size="wide">
    <TextConverter />
  </Page>
</BaseLayout>
