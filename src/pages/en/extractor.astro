---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import TextExtractor from '../../components/TextExtractor.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.extractor.title')} description={t('tool.extractor.lead')}>
  <Page title={t('tool.extractor.title')} lead={t('tool.extractor.lead')} size="wide">
    <TextExtractor />
  </Page>
</BaseLayout>
