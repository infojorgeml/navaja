---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import JsonFormatter from '../../components/JsonFormatter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.json.title')} description={t('tool.json.lead')}>
  <Page title={t('tool.json.title')} lead={t('tool.json.lead')} size="wide">
    <JsonFormatter />
  </Page>
</BaseLayout>
