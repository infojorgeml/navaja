---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import CharCounter from '../../components/CharCounter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.contador.title')} description={t('tool.contador.lead')}>
  <Page title={t('tool.contador.title')} lead={t('tool.contador.lead')} size="wide">
    <CharCounter />
  </Page>
</BaseLayout>
