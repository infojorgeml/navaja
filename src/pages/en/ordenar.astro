---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import LineSorter from '../../components/LineSorter.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.ordenar.title')} description={t('tool.ordenar.lead')}>
  <Page title={t('tool.ordenar.title')} lead={t('tool.ordenar.lead')} size="wide">
    <LineSorter />
  </Page>
</BaseLayout>
