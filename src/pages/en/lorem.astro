---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Page from '../../components/Page.astro';
import LoremGenerator from '../../components/LoremGenerator.astro';
import { getLocale, useTranslations } from '../../i18n/ui';
const t = useTranslations(getLocale(Astro));
---

<BaseLayout title={t('tool.lorem.title')} description={t('tool.lorem.lead')}>
  <Page title={t('tool.lorem.title')} lead={t('tool.lorem.lead')} size="wide">
    <LoremGenerator />
  </Page>
</BaseLayout>
