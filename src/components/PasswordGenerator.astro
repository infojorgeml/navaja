---
// src/components/PasswordGenerator.astro — genera contraseñas seguras con crypto (isla cliente)
---

<div class="pass flow">
  <div class="pass__output-row">
    <input
      id="pass-output"
      class="pass__output"
      type="text"
      readonly
      value=""
      aria-label="Contraseña generada"
    />
    <button type="button" class="btn" data-action="copy">Copiar</button>
  </div>

  <div class="pass__length">
    <label class="pass__label" for="pass-length">
      Longitud: <output id="pass-length-val">16</output>
    </label>
    <input id="pass-length" class="pass__range" type="range" min="4" max="64" value="16" />
  </div>

  <div class="pass__options">
    <label class="pass__check"><input type="checkbox" id="pass-upper" checked /> <span>Mayúsculas (A-Z)</span></label>
    <label class="pass__check"><input type="checkbox" id="pass-lower" checked /> <span>Minúsculas (a-z)</span></label>
    <label class="pass__check"><input type="checkbox" id="pass-num" checked /> <span>Números (0-9)</span></label>
    <label class="pass__check"><input type="checkbox" id="pass-sym" checked /> <span>Símbolos (!@#…)</span></label>
    <label class="pass__check"><input type="checkbox" id="pass-ambig" /> <span>Evitar ambiguos (l, 1, O, 0…)</span></label>
  </div>

  <div class="pass__actions">
    <button type="button" class="btn" data-action="generate">Generar de nuevo</button>
    <span class="pass__strength" data-strength></span>
    <span class="pass__msg" data-pass-msg hidden>¡Copiado!</span>
  </div>
</div>

<style>
  .pass__output-row {
    display: flex;
    gap: var(--spacing-s);
  }

  .pass__output {
    flex: 1;
    min-inline-size: 0;
    padding: var(--spacing-s);
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: var(--text-lg);
    color: var(--foreground);
    background-color: var(--input);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .pass__output:focus-visible {
    outline: none;
    border-color: var(--ring);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--ring) 30%, transparent);
  }

  .pass__label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    margin-block-end: var(--spacing-2xs);
  }

  .pass__range {
    inline-size: 100%;
    accent-color: var(--primary);
  }

  .pass__options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
    gap: var(--spacing-2xs) var(--spacing-m);
  }

  .pass__check {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2xs);
    font-size: var(--text-sm);
  }

  .pass__check input {
    inline-size: 1rem;
    block-size: 1rem;
    accent-color: var(--primary);
  }

  .pass__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-s);
  }

  .pass__strength,
  .pass__msg {
    font-size: var(--text-sm);
    color: var(--muted-foreground);
  }
</style>

<script>
  function initPassword() {
    const output = document.getElementById('pass-output') as HTMLInputElement | null;
    const lengthEl = document.getElementById('pass-length') as HTMLInputElement | null;
    const lengthVal = document.getElementById('pass-length-val');
    const upperEl = document.getElementById('pass-upper') as HTMLInputElement | null;
    const lowerEl = document.getElementById('pass-lower') as HTMLInputElement | null;
    const numEl = document.getElementById('pass-num') as HTMLInputElement | null;
    const symEl = document.getElementById('pass-sym') as HTMLInputElement | null;
    const ambigEl = document.getElementById('pass-ambig') as HTMLInputElement | null;
    const strengthEl = document.querySelector<HTMLElement>('[data-strength]');
    const msg = document.querySelector<HTMLElement>('[data-pass-msg]');
    if (!output || !lengthEl) return;

    const SETS = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      num: '0123456789',
      sym: '!@#$%^&*()-_=+[]{};:,.?',
    };
    const AMBIG = /[Il1O0o]/g;

    // Entero uniforme en [0, max) con crypto (rejection sampling, sin sesgo de módulo).
    function secureInt(max: number): number {
      const arr = new Uint32Array(1);
      const limit = Math.floor(0x100000000 / max) * max;
      let x = 0;
      do {
        crypto.getRandomValues(arr);
        x = arr[0];
      } while (x >= limit);
      return x % max;
    }

    function updateStrength(len: number, variety: number) {
      if (!strengthEl) return;
      let label = 'Débil';
      if (len >= 16 && variety >= 3) label = 'Muy fuerte';
      else if (len >= 12 && variety >= 2) label = 'Fuerte';
      else if (len >= 8) label = 'Media';
      strengthEl.textContent = 'Seguridad: ' + label;
    }

    function generate() {
      const avoid = ambigEl?.checked ?? false;
      const clean = (s: string) => (avoid ? s.replace(AMBIG, '') : s);
      const pools: string[] = [];
      if (upperEl?.checked) pools.push(clean(SETS.upper));
      if (lowerEl?.checked) pools.push(clean(SETS.lower));
      if (numEl?.checked) pools.push(clean(SETS.num));
      if (symEl?.checked) pools.push(clean(SETS.sym));

      if (!pools.length) {
        output!.value = '';
        if (strengthEl) strengthEl.textContent = 'Elige al menos un tipo de carácter';
        return;
      }

      const len = parseInt(lengthEl!.value, 10);
      const all = pools.join('');
      const chars: string[] = [];
      // garantiza al menos uno de cada tipo elegido
      for (const p of pools) chars.push(p[secureInt(p.length)]);
      while (chars.length < len) chars.push(all[secureInt(all.length)]);
      chars.length = len;
      // mezcla Fisher-Yates con aleatoriedad segura
      for (let i = chars.length - 1; i > 0; i--) {
        const j = secureInt(i + 1);
        [chars[i], chars[j]] = [chars[j], chars[i]];
      }
      output!.value = chars.join('');
      updateStrength(len, pools.length);
    }

    lengthEl.addEventListener('input', () => {
      if (lengthVal) lengthVal.textContent = lengthEl.value;
      generate();
    });
    [upperEl, lowerEl, numEl, symEl, ambigEl].forEach((el) => el?.addEventListener('change', generate));

    document.querySelectorAll<HTMLButtonElement>('[data-action]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (btn.dataset.action === 'generate') {
          generate();
        } else if (btn.dataset.action === 'copy') {
          if (!output!.value) return;
          try {
            await navigator.clipboard.writeText(output!.value);
            if (msg) {
              msg.hidden = false;
              setTimeout(() => (msg.hidden = true), 1500);
            }
          } catch {}
        }
      });
    });

    if (lengthVal) lengthVal.textContent = lengthEl.value;
    generate();
  }

  document.addEventListener('astro:page-load', initPassword);
</script>
