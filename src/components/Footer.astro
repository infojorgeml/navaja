---
// src/components/Footer.astro — pie de página
import { getLocale, useTranslations } from '../i18n/ui';
const locale = getLocale(Astro);
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner boxed">
    <p class="footer__left">{t('footer.rights', { year })}</p>
    <p class="footer__right">
      <span class="footer__os">{t('footer.os')}</span>
      <span class="footer__sep" aria-hidden="true">·</span>
      <span>{t('footer.by')} <a href="https://jorgeml.com/" target="_blank" rel="noopener noreferrer">JorgeML</a></span>
    </p>
  </div>
</footer>

<style>
  .footer {
    border-block-start: 1px solid var(--border);
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-2xs) var(--spacing-m);
    padding-block: var(--spacing-m);
  }

  .footer__left,
  .footer__right {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .footer__right {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2xs);
  }

  .footer__sep {
    opacity: 0.5;
  }

  .footer a {
    color: var(--foreground);
    text-decoration: none;
    font-weight: 500;
  }

  .footer a:hover {
    text-decoration: underline;
  }
</style>
