---
// src/components/Header.astro — marca + buscador ⌘K + selector de idioma + tema.
// La navegación entre módulos vive en la home (índice) y en el command palette.
import { getRelativeLocaleUrl } from 'astro:i18n';
import ThemeToggle from './ThemeToggle.astro';
import { getLocale, useTranslations, basePath } from '../i18n/ui';

const locale = getLocale(Astro);
const t = useTranslations(locale);
const base = basePath(Astro.url.pathname);
const esUrl = getRelativeLocaleUrl('es', base);
const enUrl = getRelativeLocaleUrl('en', base);
const brandUrl = getRelativeLocaleUrl(locale, '');
---

<header class="header">
  <div class="header__inner boxed">
    <a class="header__brand" href={brandUrl}>Navaja</a>

    <div class="header__right">
      <button
        type="button"
        class="header__search"
        data-command-open
        aria-label={t('chrome.searchAria')}
        aria-keyshortcuts="Meta+K Control+K"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="header__search-label">{t('chrome.search')}</span>
        <kbd class="header__kbd">⌘K</kbd>
      </button>

      <div class="lang" role="group" aria-label={t('chrome.langAria')}>
        <a class="lang__opt" href={esUrl} aria-current={locale === 'es' ? 'true' : 'false'} hreflang="es">ES</a>
        <a class="lang__opt" href={enUrl} aria-current={locale === 'en' ? 'true' : 'false'} hreflang="en">EN</a>
      </div>

      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    inset-block-start: 0;
    z-index: 20;
    border-block-end: 1px solid var(--border);
    background-color: color-mix(in oklab, var(--background) 80%, transparent);
    backdrop-filter: blur(10px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-s);
    block-size: 4rem;
  }

  /* Wordmark: el único momento en peso 600 del sistema (OpenAI design.md). */
  .header__brand {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--foreground);
    text-decoration: none;
  }

  .header__right {
    display: flex;
    align-items: center;
    gap: var(--spacing-2xs);
  }

  /* Buscador como mini-pill estilo input de OpenAI: lienzo + hairline, full-round. */
  .header__search {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2xs);
    padding-block: var(--spacing-3xs);
    padding-inline: var(--spacing-s);
    font: inherit;
    font-size: 0.875rem;
    color: var(--muted-foreground);
    background-color: var(--background);
    border: 1px solid var(--border);
    border-radius: 9999px; /* pill */
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .header__search:hover {
    color: var(--foreground);
    border-color: var(--foreground);
  }

  .header__search:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .header__search svg {
    inline-size: 1rem;
    block-size: 1rem;
    flex: none;
  }

  .header__search-label,
  .header__kbd {
    display: none;
  }

  .header__kbd {
    font-family: inherit;
    font-size: var(--text-2xs);
    padding-block: 0.1rem;
    padding-inline: 0.35rem;
    color: var(--muted-foreground);
    background-color: var(--background);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) - 4px);
  }

  /* Selector de idioma: control segmentado en pill (activo = tinta). */
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 2px;
    border: 1px solid var(--border);
    border-radius: 9999px;
  }

  .lang__opt {
    display: inline-flex;
    align-items: center;
    padding-block: 0.15rem;
    padding-inline: 0.5rem;
    font-size: var(--text-2xs);
    font-weight: 500;
    line-height: 1;
    color: var(--muted-foreground);
    text-decoration: none;
    border-radius: 9999px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .lang__opt:hover {
    color: var(--foreground);
  }

  .lang__opt[aria-current='true'] {
    color: var(--primary-foreground);
    background-color: var(--primary);
  }

  .lang__opt:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  @media (min-width: 640px) {
    .header__search-label,
    .header__kbd {
      display: inline-block;
    }
  }
</style>
